# ── SAR Backend Environment Variables ────────────────────
# Copy this file to .env and adjust values as needed.

# Application
APP_NAME=SAR-Multi-Agent-Backend
APP_VERSION=1.0.0
APP_ENV=development          # development | staging | production
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1                    # Increase for production (e.g. 4)

# Logging
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json              # json | text

# Cache
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300        # 5 minutes
CACHE_MAX_SIZE=128

# Agent Configuration
AGENT_TIMEOUT_SECONDS=30     # Per-agent execution timeout

# Rate Limiting
RATE_LIMIT_RPM=60            # Max requests per minute per client
